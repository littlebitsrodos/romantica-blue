{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/neuralnode/Developer/sea-tree-paros/.codex/hooks/check-gstack.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .agent/tools/memory_reflect.py claude-code post-tool ok"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .agent/memory/auto_dream.py"
          }
        ]
      }
    ]
  }
}
